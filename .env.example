# Gemini
GEMINI_API_KEY=your-gemini-api-key
GEMINI_SCRIPT_MODEL=gemini-2.5-pro
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts


# Claude
ANTHROPIC_API_KEY=your-anthropic-api-key
